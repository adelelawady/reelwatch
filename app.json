{
  "expo": {
    "name": "ReelWatch",
    "slug": "reelwatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reelwatch",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.adelelawady.reelwatch",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.adelelawady.reelwatch"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "be5b5a31-e1b9-4b59-aa86-4576088f0302"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/be5b5a31-e1b9-4b59-aa86-4576088f0302",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
