{
  "expo": {
    "name": "ReelWatch",
    "slug": "reelwatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reelwatch",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reelwatch.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.reelwatch.app",
      "softwareKeyboardLayoutMode": "adjustNothing"
    },
    "plugins": ["expo-router"]
  }
}
